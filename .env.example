# Copy to .env and fill in your key:  cp .env.example .env
OPENAI_API_KEY=sk-...

# Models (override the defaults if you like)
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# Weaviate (local docker-compose default)
WEAVIATE_HOST=localhost
WEAVIATE_HTTP_PORT=8080
WEAVIATE_GRPC_PORT=50051

# Retrieval defaults
DEFAULT_ALPHA=0.5
DEFAULT_TOP_K=5
SUMMARY_TOP_K=40
# Minimum hybrid score a chunk must clear for /ask to attempt an answer (else refuse)
REFUSAL_SCORE_THRESHOLD=0.15

# API base used by the Streamlit UI
API_BASE_URL=http://localhost:8000
